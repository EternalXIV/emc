local player = game:GetService("Players").LocalPlayer

local nicknameMap = {
    ["Melee"] = {"dragontalon", "sharkman", "electricclaw", "superhuman", "darkstep", "waterkunai", "deathstep", "fishmankarate", "sanguine"},
    ["Devil Fruit"] = {"buddha", "dough", "light", "magma", "flame", "ice", "dark", "quake", "love", "sound", "spider", "portal", "gravity", "rubber", "sand", "smoke", "ghost", "diamond", "eagle", "creation"},
    ["Sword"] = {"dragonheart", "tushita", "yama", "rengoku", "scythe", "cursedkatana", "saber", "trident", "longsword"},
    ["Gun"] = {"dragonstorm", "kabucha", "acidgun", "slingshot"},
}

local function getToolLevel(category)
    local nicknames = nicknameMap[category]
    if not nicknames then return 0 end
    
    local sources = {player.Backpack}
    if player.Character then table.insert(sources, player.Character) end
    
    -- เช็ค workspace.Characters ด้วย
    local chars = workspace:FindFirstChild("Characters")
    if chars and chars:FindFirstChild(player.Name) then
        table.insert(sources, chars[player.Name])
    end
    
    for _, source in pairs(sources) do
        for _, tool in pairs(source:GetChildren()) do
            local nick = tool:FindFirstChild("Nickname")
            local level = tool:FindFirstChild("Level")
            if nick and level then
                for _, n in pairs(nicknames) do
                    if string.lower(nick.Value) == n then
                        return level.Value
                    end
                end
            end
        end
    end
    return 0
end

while true do
    local descParts = {}
    local allDone = true

    for category, requiredLevel in pairs(getgenv().HorstConfig) do
        if requiredLevel == -1 then continue end
        local currentLevel = getToolLevel(category)
        local status = currentLevel >= requiredLevel and "✅" or "❌"
        if currentLevel < requiredLevel then allDone = false end
        table.insert(descParts, status .. " " .. category .. " " .. currentLevel .. "/" .. requiredLevel)
    end

    _G.Horst_SetDescription(table.concat(descParts, " | "))

    if allDone then
        _G.Horst_AccountChangeDone()
        break
    end

    task.wait(10)
end
