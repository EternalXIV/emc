function UnitDataManager:Initialize()
    task.spawn(function()
        local Packages = game:GetService("ReplicatedStorage"):WaitForChild("Packages", 10)
        if not Packages then return end
        
        local Index = Packages:WaitForChild("_Index", 10)
        if not Index then return end
        
        local KnitPkg = nil
        for _, child in ipairs(Index:GetChildren()) do
            if child.Name:match("sleitnick_knit") then
                KnitPkg = child
                break
            end
        end
        
        if KnitPkg then
            local Knit = require(KnitPkg.knit)

            local possibleNames = {"DataController", "InventoryController", "UnitController", "PlayerController"}
            
            if type(Knit.GetController) == "function" then
                for _, name in ipairs(possibleNames) do
                    local success, ctrl = pcall(function() return Knit.GetController(name) end)
                    if success and ctrl then
                        self.Controller = ctrl
                        break
                    end
                end
            end

            if not self.Controller and rawget(Knit, "Controllers") then
                for _, name in ipairs(possibleNames) do
                    if Knit.Controllers[name] then
                        self.Controller = Knit.Controllers[name]
                        break
                    end
                end
            end
            
            if not self.Controller and rawget(Knit, "Controllers") then
                for _, controller in pairs(Knit.Controllers) do
                    if (controller.EquippedUnits or (controller.Replica and controller.Replica.Data and controller.Replica.Data.EquippedUnits)) then
                        self.Controller = controller
                        break
                    end
                    if controller.Replica and controller.Replica.Data and controller.Replica.Data.PlayerData and controller.Replica.Data.PlayerData.Units and controller.Replica.Data.PlayerData.Units.Equipped then
                        self.Controller = controller
                        break
                    end
                end
            end
            
            if getgenv().UTD_DebugMode then
                warn("[UTD] UnitDataManager: Controller found? " .. tostring(self.Controller ~= nil))
            end
        end
    end)
end

function UnitDataManager:GetData()
    if self.Controller then
        if self.Controller.EquippedUnits then return self.Controller end
        if self.Controller.PlayerData then return self.Controller end
        if self.Controller.Replica and self.Controller.Replica.Data then return self.Controller.Replica.Data end
        if self.Controller.Data then return self.Controller.Data end
    end
    return nil
end

function UnitDataManager:GetUnitNameFromSlot(slot)
    local data = self:GetData()
    if data then
        local equipped = data.EquippedUnits 
            or (data.PlayerData and data.PlayerData.Units and data.PlayerData.Units.Equipped)
            or (data.Units and data.Units.Equipped)
            
        local inventory = data.Inventory or data.UnitInventory

        if equipped and inventory then
            local guid = equipped[tonumber(slot)]
            if guid then
                local unitData = inventory[guid]
                if unitData then
                    return unitData.UnitId
                end
            end
        end
    end
    return nil
end

function UnitDataManager:GetSlotFromUnitName(unitName)
    local data = self:GetData()
    if data then
        local equipped = data.EquippedUnits 
            or (data.PlayerData and data.PlayerData.Units and data.PlayerData.Units.Equipped)
            or (data.Units and data.Units.Equipped)
            
        local inventory = data.Inventory or data.UnitInventory

        if equipped and inventory then
            for slot, guid in pairs(equipped) do
                local unitData = inventory[guid]
                if unitData and unitData.UnitId == unitName then
                    return slot
                end
            end
        end
        
        if getgenv().UTD_DebugMode then
            warn("[UTD Debug] GetSlotFromUnitName failed for " .. tostring(unitName))
            warn("Data found: " .. tostring(data ~= nil))
            warn("Equipped found: " .. tostring(equipped ~= nil))
            warn("Inventory found: " .. tostring(inventory ~= nil))
        end
    end
    return nil
end

function TowerDataManager:GetTowerStats(unitName)
    if self.Cache[unitName] then return self.Cache[unitName] end
    
    local rs = game:GetService("ReplicatedStorage")
    local paths = {
        rs:FindFirstChild("Shared") and rs.Shared:FindFirstChild("Data") and rs.Shared.Data:FindFirstChild("Towers"),
        rs:FindFirstChild("Network") and rs.Network:FindFirstChild("Data") and rs.Network.Data:FindFirstChild("Towers"),
        rs:FindFirstChild("Data") and rs.Data:FindFirstChild("Towers")
    }

    for _, folder in ipairs(paths) do
        if folder then
            local module = folder:FindFirstChild(unitName)
            if module then
                local success, data = pcall(function() return require(module) end)
                if success and data and data.Stats then
                    self.Cache[unitName] = data.Stats
                    return data.Stats
                end
            end
        end
    end
    
    if getgenv().UTD_DebugMode then
        warn("[UTD] TowerDataManager: Could not find stats for " .. tostring(unitName))
        for _, folder in ipairs(paths) do
            if folder then
                warn("Available units in " .. folder:GetFullName() .. ":")
                for _, child in ipairs(folder:GetChildren()) do
                    warn(" - " .. child.Name)
                end
                break 
            end
        end
    end
    return nil
end

