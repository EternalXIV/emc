local function GetGamemodes()
    local modes = {}
    local rs = game:GetService("ReplicatedStorage")
    local shared = rs:WaitForChild("Shared", 5)
    
    if shared then
        local gmModule = shared:FindFirstChild("GamemodeType")
        if gmModule then
            local success, data = pcall(require, gmModule)
            if success and type(data) == "table" then
                for _, v in pairs(data) do 
                    if not table.find(modes, v) then
                        table.insert(modes, v) 
                    end
                end
            end
        end
    end
    
    local defaults = {"Story", "Infinite", "VirtualRealm"}
    for _, d in ipairs(defaults) do
        if not table.find(modes, d) then
            table.insert(modes, d)
        end
    end

    if not table.find(modes, "Legend") then table.insert(modes, "Legend") end
    if not table.find(modes, "Challenge") then table.insert(modes, "Challenge") end
    
    table.sort(modes)
    return modes
end

local function GetMapsForMode(mode)
    local maps = {}
    local rs = game:GetService("ReplicatedStorage")
    local shared = rs:WaitForChild("Shared", 5)
    if not shared then return {} end
    
    local function addMapsFromFolder(folderName, includeActs)
        local targetFolder = shared:FindFirstChild(folderName)
        if targetFolder then
            for _, folder in ipairs(targetFolder:GetChildren()) do
                if folder:IsA("Folder") then
                    if includeActs then
                        local acts = {}
                        for _, file in ipairs(folder:GetChildren()) do
                            if file:IsA("ModuleScript") then
                                local name = file.Name:gsub("%.lua", "")
                                if tonumber(name) then
                                    table.insert(acts, tonumber(name))
                                end
                            end
                        end
                        table.sort(acts)
                        for _, act in ipairs(acts) do
                            table.insert(maps, folder.Name .. " - Act " .. act)
                        end
                    else
                        if not table.find(maps, folder.Name) then
                            table.insert(maps, folder.Name)
                        end
                    end
                end
            end
        end
    end

    if mode == "Story" then
        addMapsFromFolder("Waves", true)
    elseif mode == "VirtualRealm" then
        addMapsFromFolder("VirtualRealm", true)
    elseif mode == "Legend" then
        addMapsFromFolder("LegendStages", true)
    elseif mode == "Infinite" then
        local waves = shared:FindFirstChild("Waves")
        if waves then
            for _, folder in ipairs(waves:GetChildren()) do
                if folder:IsA("Folder") then
                    if folder:FindFirstChild("Infinite") or folder:FindFirstChild("Infinite.lua") then
                        table.insert(maps, folder.Name)
                    end
                end
            end
        end
    elseif mode == "Challenge" then
        local waves = shared:FindFirstChild("Waves")
        if waves then
            for _, folder in ipairs(waves:GetChildren()) do
                if folder:IsA("Folder") then
                    if not table.find(maps, folder.Name) then
                        table.insert(maps, folder.Name)
                    end
                end
            end
        end
        addMapsFromFolder("VirtualRealm", false)
        addMapsFromFolder("LegendStages", false)
    end
    
    table.sort(maps)
    return maps
end

