local ConfigManager = {}
ConfigManager.Folder = "ByorlLastStand/Universal Tower Defense/" .. LocalPlayer.UserId
ConfigManager.Elements = {}
ConfigManager.Flags = {}
ConfigManager.CurrentConfig = "default"

function ConfigManager:Initialize()
    if not isfolder("ByorlLastStand") then makefolder("ByorlLastStand") end
    if not isfolder("ByorlLastStand/Universal Tower Defense") then makefolder("ByorlLastStand/Universal Tower Defense") end
    if not isfolder(self.Folder) then makefolder(self.Folder) end
    
    self:LoadAutoLoad()
end

function ConfigManager:Register(flag, element, type)
    self.Elements[flag] = {
        Element = element,
        Type = type
    }
    self.Flags[flag] = element
end

function ConfigManager:GetConfigPath(name)
    return self.Folder .. "/" .. name .. ".json"
end

function ConfigManager:Save(name)
    name = name or self.CurrentConfig
    local config = {}
    
    for flag, data in pairs(self.Elements) do
        local element = data.Element
        local type = data.Type
        
        if not element then continue end

        if type == "Toggle" then
            config[flag] = element.State
        elseif type == "Slider" then
            config[flag] = element.Value
        elseif type == "Dropdown" then
            config[flag] = element.Value
        elseif type == "Input" then
            config[flag] = element.Text
        elseif type == "Colorpicker" then
            if element.Color then
                config[flag] = {
                    R = element.Color.R,
                    G = element.Color.G,
                    B = element.Color.B,
                    Alpha = element.Alpha
                }
            end
        elseif type == "Keybind" then
            if element.GetBind then
                config[flag] = element:GetBind().Name
            end
        end
    end
    
    writefile(self:GetConfigPath(name), HttpService:JSONEncode(config))
end

function ConfigManager:Load(name)
    local path = self:GetConfigPath(name)
    if not isfile(path) then return end
    
    local success, config = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    
    if not success then return end
    
    self.CurrentConfig = name
    local wasAutoSave = GlobalConfig.Data.AutoSave
    GlobalConfig.Data.AutoSave = false
    
    for flag, value in pairs(config) do
        local data = self.Elements[flag]
        if data then
            local element = data.Element
            local type = data.Type
            
            if not element then continue end

            if type == "Toggle" then
                if element.UpdateState then element:UpdateState(value) end
            elseif type == "Slider" then
                if element.UpdateValue then element:UpdateValue(value) end
            elseif type == "Dropdown" then
                if element.UpdateSelection then element:UpdateSelection(value) end
            elseif type == "Input" then
                if element.UpdateText then element:UpdateText(value) end
            elseif type == "Colorpicker" then
                if element.SetColor and element.SetAlpha then
                    element:SetColor(Color3.new(value.R, value.G, value.B))
                    element:SetAlpha(value.Alpha)
                end
            elseif type == "Keybind" then
                if element.Bind then element:Bind(Enum.KeyCode[value]) end
            end
        end
    end
    
    GlobalConfig.Data.AutoSave = wasAutoSave
end

function ConfigManager:Delete(name)
    local path = self:GetConfigPath(name)
    if isfile(path) then
        delfile(path)
    end
end

function ConfigManager:GetConfigs()
    local configs = {}
    if isfolder(self.Folder) then
        for _, file in ipairs(listfiles(self.Folder)) do
            if file:sub(-5) == ".json" then
                table.insert(configs, file:match("([^\\/]+)%.json$"))
            end
        end
    end
    return configs
end

function ConfigManager:SetAutoLoad(name)
    writefile(self.Folder .. "/autoload.txt", name)
end

function ConfigManager:LoadAutoLoad()
    if isfile(self.Folder .. "/autoload.txt") then
        local name = readfile(self.Folder .. "/autoload.txt")
        self:Load(name)
    end
end

local UI = {}

function UI.WrapCallback(callback)
    return function(...)
        if callback then callback(...) end
        if GlobalConfig.Data.AutoSave then
            ConfigManager:Save()
        end
    end
end

function UI.Toggle(section, options, flag)
    options.Callback = UI.WrapCallback(options.Callback)
    local element = section:Toggle(options)
    if flag then ConfigManager:Register(flag, element, "Toggle") end
    return element
end

function UI.Slider(section, options, flag)
    if options.Min then options.Minimum = options.Min end
    if options.Max then options.Maximum = options.Max end
    if options.Decimals then options.Precision = options.Decimals end

    if options.Minimum == nil then options.Minimum = 0 end
    if options.Maximum == nil then options.Maximum = 100 end
    if options.Default == nil then options.Default = options.Minimum end
    if options.Precision == nil then options.Precision = 1 end

    options.Callback = UI.WrapCallback(options.Callback)
    local element = section:Slider(options)
    if flag then ConfigManager:Register(flag, element, "Slider") end
    return element
end

function UI.Dropdown(section, options, flag)
    if options.Search == nil then options.Search = true end
    options.Callback = UI.WrapCallback(options.Callback)
    local element = section:Dropdown(options)
    if flag then ConfigManager:Register(flag, element, "Dropdown") end
    return element
end

function UI.Input(section, options, flag)
    options.Callback = UI.WrapCallback(options.Callback)
    local element = section:Input(options)
