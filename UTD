function MacroManager:GetUnitIdAtPosition(targetCFrame)
    local closestUnit = nil
    local minDistance = 5
    
    local unitsFolder = workspace:FindFirstChild("Ignore") and workspace.Ignore:FindFirstChild("Units")
    if not unitsFolder then return nil end
    
    for _, unit in ipairs(unitsFolder:GetChildren()) do
        local hrp = unit:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(targetCFrame.Position.X, 0, targetCFrame.Position.Z)).Magnitude
            if dist < minDistance then
                minDistance = dist
                closestUnit = unit
            end
        end
    end
    
    return closestUnit and closestUnit.Name or nil
end

function MacroManager:SetupHooks()
    getgenv().UTD_HookLogic = function(self, args, method, oldNamecall)
        local remoteName = self.Name
        
        if getgenv().UTD_MacroManager.IsRecording and game.PlaceId == 106402284955512 then
            task.spawn(function()
                local Manager = getgenv().UTD_MacroManager
                if remoteName == "PlaceUnit" then
                    local slot = args[1]
                    local cframe = args[2]
                    
                    if slot and typeof(cframe) == "CFrame" then
                        local lastStep = Manager.RecordedSteps[#Manager.RecordedSteps]
                        local isDuplicate = false
                        if lastStep and lastStep.Type == "Place" and lastStep.Slot == slot then
                             local lastPos = Vector3.new(lastStep.CFrame.X, lastStep.CFrame.Y, lastStep.CFrame.Z)
                             if (lastPos - cframe.Position).Magnitude < 1 then
                                 isDuplicate = true
                             end
                        end

                        if not isDuplicate then
                            local unitName = UnitDataManager:GetUnitNameFromSlot(slot)
                            local step = {
                                Type = "Place",
                                Slot = slot,
                                UnitName = unitName,
                                CFrame = {
                                    X = cframe.X, Y = cframe.Y, Z = cframe.Z,
                                    R00 = cframe.RightVector.X, R01 = cframe.RightVector.Y, R02 = cframe.RightVector.Z,
                                    R10 = cframe.UpVector.X, R11 = cframe.UpVector.Y, R12 = cframe.UpVector.Z,
                                    R20 = cframe.LookVector.X, R21 = cframe.LookVector.Y, R22 = cframe.LookVector.Z
                                },
                                Time = workspace:GetAttribute("WaveTimer") or 0,
                                Wave = workspace:GetAttribute("Wave") or 0
                            }
                            table.insert(Manager.RecordedSteps, step)
                            local display = unitName and (unitName .. " (Slot " .. slot .. ")") or ("Slot " .. slot)
                            Manager:UpdateStatus("Recorded Place Unit (" .. #Manager.RecordedSteps .. ")", "Place", display, "None")
                        end
                    end
                
                elseif remoteName == "UpgradeUnit" then
                    local unitId = args[1]
                    local unit = workspace.Ignore.Units:FindFirstChild(unitId)
                    if unit then
                        local pos = unit:FindFirstChild("HumanoidRootPart") and unit.HumanoidRootPart.Position or Vector3.zero
                        local step = {
                            Type = "Upgrade",
                            Position = {X = pos.X, Y = pos.Y, Z = pos.Z},
                            Time = workspace:GetAttribute("WaveTimer") or 0,
                            Wave = workspace:GetAttribute("Wave") or 0
                        }
                        table.insert(Manager.RecordedSteps, step)
                        Manager:UpdateStatus("Recorded Upgrade Unit (" .. #Manager.RecordedSteps .. ")", "Upgrade", tostring(unitId), "None")
                    end
                
                elseif remoteName == "SellUnit" then
                    local unitId = args[1]
                    local unit = workspace.Ignore.Units:FindFirstChild(unitId)
                    if unit then
                        local pos = unit:FindFirstChild("HumanoidRootPart") and unit.HumanoidRootPart.Position or Vector3.zero
                        local step = {
                            Type = "Sell",
                            Position = {X = pos.X, Y = pos.Y, Z = pos.Z},
                            Time = workspace:GetAttribute("WaveTimer") or 0,
                            Wave = workspace:GetAttribute("Wave") or 0
                        }
                        table.insert(Manager.RecordedSteps, step)
                        Manager:UpdateStatus("Recorded Sell Unit (" .. #Manager.RecordedSteps .. ")", "Sell", tostring(unitId), "None")
                    end

                elseif string.find(remoteName, "Ability") then
                    local unitId = args[1]
                    local unit = workspace.Ignore.Units:FindFirstChild(unitId)
                    if unit then
                        local pos = unit:FindFirstChild("HumanoidRootPart") and unit.HumanoidRootPart.Position or Vector3.zero
                        local step = {
                            Type = "Ability",
                            Position = {X = pos.X, Y = pos.Y, Z = pos.Z},
                            AbilityName = remoteName,
                            Time = workspace:GetAttribute("WaveTimer") or 0,
                            Wave = workspace:GetAttribute("Wave") or 0
                        }
                        table.insert(Manager.RecordedSteps, step)
                        Manager:UpdateStatus("Recorded Ability (" .. #Manager.RecordedSteps .. ")", "Ability", tostring(unitId), "None")
                    end
                end
            end)
        end

        if getgenv().UTD_DebugMode then
            if remoteName == "PlaceUnit" or remoteName == "UpgradeUnit" or remoteName == "SellUnit" or string.find(remoteName, "Ability") then
                local results = {oldNamecall(self, unpack(args))}
                pcall(function()
                    local info = ""
                    if remoteName == "PlaceUnit" then
                        local slot = args[1]
                        local cframe = args[2]
                        info = "Slot: " .. tostring(slot)
                        
                        local unitName = UnitDataManager:GetUnitNameFromSlot(slot)
                        if unitName then
                            info = info .. " | Unit: " .. tostring(unitName)
                        end

                        if typeof(cframe) == "CFrame" then
                            local unitId = getgenv().UTD_MacroManager:GetUnitIdAtPosition(cframe)
                            if unitId then
                                local unit = workspace:FindFirstChild("Ignore") and workspace.Ignore:FindFirstChild("Units") and workspace.Ignore.Units:FindFirstChild(unitId)
                                if unit then
                                    local realName = unit:GetAttribute("UnitName") or unit:GetAttribute("Name") or unit.Name
                                    info = info .. " | Spawned: " .. tostring(realName) .. " (" .. tostring(unitId) .. ")"
                                else
                                    info = info .. " | ID: " .. tostring(unitId)
                                end
                            end
                        end

                        if not info:find("Spawned:") and results[1] == true then
                            local msg = tostring(results[2])
                            local id = msg:match("Placed unit ([%w%-]+)")
                            if id then
                                local unit = workspace:FindFirstChild("Ignore") and workspace.Ignore:FindFirstChild("Units") and workspace.Ignore.Units:FindFirstChild(id)
                                if unit then
                                    info = info .. " | Unit: " .. unit.Name
                                end
                            end
                        end
                    elseif remoteName == "UpgradeUnit" or remoteName == "SellUnit" or string.find(remoteName, "Ability") then
                        local unitId = args[1]
                        local unit = workspace:FindFirstChild("Ignore") and workspace.Ignore:FindFirstChild("Units") and workspace.Ignore.Units:FindFirstChild(unitId)
                        if unit then
                            info = "Unit: " .. unit.Name .. " | ID: " .. tostring(unitId)
                        else
                            info = "Unit ID: " .. tostring(unitId)
                        end
                    end

                    warn("[UTD Debug] Call: " .. remoteName)
                    warn(" -> Info: " .. info)
                    warn(" -> Args:", unpack(args))
                    warn(" -> Return:", unpack(results))
                end)
                return unpack(results)
            end
        end
        
        return oldNamecall(self, unpack(args))
    end

    if getgenv().UTD_HookInstalled then return end
    getgenv().UTD_HookInstalled = true

    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if method == "InvokeServer" or method == "FireServer" then
            if getgenv().UTD_HookLogic then
                return getgenv().UTD_HookLogic(self, args, method, oldNamecall)
            end
        end

        return oldNamecall(self, ...)
    end)
    
    setreadonly(mt, true)
end

function MacroManager:Play()
    if not self.CurrentMacro then return end
    if game.PlaceId ~= 106402284955512 then
        Window:Notify({
            Title = "Macro",
            Description = "Macros can only be played in-game!",
            Lifetime = 3
        })
        return 
    end

    self.IsPlaying = true
    
    task.spawn(function()
        local TowerService = game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit.Services.TowerService
        local stepIndex = 1
        self.PlacedHistory = {}
        
        while self.IsPlaying do
            if game.PlaceId ~= 106402284955512 then
                self.IsPlaying = false
                break
            end

            if not self.CurrentMacro then break end
            if stepIndex > #self.CurrentMacro then
                self:UpdateStatus("Waiting for match to end...", "None", "None", "Match Finish")
                
                repeat task.wait(1) until workspace:GetAttribute("MatchFinished")
                
                self:UpdateStatus("Waiting for new match...", "None", "None", "Lobby/Loading")
                
                repeat task.wait(1) until not workspace:GetAttribute("MatchFinished")
                
                repeat task.wait(1) until workspace:GetAttribute("Started")
                
                stepIndex = 1
                self.PlacedHistory = {} 
                self:UpdateStatus("Restarting Macro", "None", "None", "None")
            end
            
            if not workspace:GetAttribute("Started") then
                self:UpdateStatus("Waiting for game start...", "None", "None", "Game Start")
                task.wait(1)
                continue
            end
            
            local step = self.CurrentMacro[stepIndex]
            local success = false
            local totalSteps = #self.CurrentMacro
            local statusMsg = "Step " .. stepIndex .. "/" .. totalSteps
            
            if step.Type == "Place" then
                local cf = CFrame.new(
                    step.CFrame.X, step.CFrame.Y, step.CFrame.Z,
                    step.CFrame.R00, step.CFrame.R01, step.CFrame.R02,
                    step.CFrame.R10, step.CFrame.R11, step.CFrame.R12,
                    step.CFrame.R20, step.CFrame.R21, step.CFrame.R22
                )
                
                local useSlot = step.Slot
                local unitName = step.UnitName
                
                if unitName then
                    local foundSlot = UnitDataManager:GetSlotFromUnitName(unitName)
                    if foundSlot then
                        useSlot = foundSlot
                    end
                end
                
                local display = unitName and (unitName .. " (Slot " .. useSlot .. ")") or ("Slot " .. useSlot)

                local alreadyPlaced = false
                if self.PlacedHistory then
                    for _, placed in ipairs(self.PlacedHistory) do
                         local dist = (Vector3.new(placed.X, 0, placed.Z) - Vector3.new(cf.Position.X, 0, cf.Position.Z)).Magnitude
                         if dist < 1 then
                             alreadyPlaced = true
                             break
                         end
                    end
                end

                if alreadyPlaced or self:GetUnitIdAtPosition(cf) then
                    success = true
                    self:UpdateStatus(statusMsg, "Place", display, "Skipped (Exists)")
                    task.wait(0.1)
                else
                    self:UpdateStatus(statusMsg, "Place", display, "None")
                    local attempts = 0
                    
                    local requiredMoney = 0
                    if unitName then
                        local stats = TowerDataManager:GetTowerStats(unitName)
                        if stats and stats.Upgrades and stats.Upgrades[1] then
                            requiredMoney = stats.Upgrades[1].Cost or 0
                        end
                    end

                    repeat
                        local currentYen = LocalPlayer:GetAttribute("Yen") or 0
                        
                        if currentYen >= requiredMoney then
                            local results = {TowerService.RF.PlaceUnit:InvokeServer(useSlot, cf)}
                            if getgenv().UTD_DebugMode then
                                warn("[UTD Debug] PlaceUnit:", unpack(results))
                            end
                            
                            if results[1] then
                                success = true
                                if self.PlacedHistory then
                                    table.insert(self.PlacedHistory, cf.Position)
                                end
                                task.wait(0.5) 
                            else
                                task.wait(0.5)
                                if self:GetUnitIdAtPosition(cf) then
                                    success = true
                                    if self.PlacedHistory then
                                        table.insert(self.PlacedHistory, cf.Position)
                                    end
                                else
                                    self:UpdateStatus(statusMsg, "Place", display, "Retrying...")
                                    task.wait(0.5)
                                    attempts = attempts + 1
                                end
                            end
                        else
                            local costStr = (requiredMoney > 0) and tostring(requiredMoney) or "?"
                            self:UpdateStatus(statusMsg, "Place", display, "Waiting for Money (" .. currentYen .. "/" .. costStr .. ")")
                            task.wait(0.5)
                        end
                    until success or not self.IsPlaying or attempts > 100
                end
                
            elseif step.Type == "Upgrade" then
                local pos = Vector3.new(step.Position.X, step.Position.Y, step.Position.Z)
                local cf = CFrame.new(pos)
                
                local inferredUnitName = nil
                for i = 1, stepIndex - 1 do
                    local prevStep = self.CurrentMacro[i]
                    if prevStep.Type == "Place" then
                        local prevPos = Vector3.new(prevStep.CFrame.X, prevStep.CFrame.Y, prevStep.CFrame.Z)
                        local dist = (Vector3.new(prevPos.X, 0, prevPos.Z) - Vector3.new(pos.X, 0, pos.Z)).Magnitude
                        if dist < 1 then
                            local slot = prevStep.Slot
                            if prevStep.UnitName then
                                inferredUnitName = prevStep.UnitName
                            else
                                inferredUnitName = UnitDataManager:GetUnitNameFromSlot(slot)
                            end
                            break
                        end
                    end
                end
                
                local attempts = 0
                repeat
                    local unitId = self:GetUnitIdAtPosition(cf)
                    if unitId then
                        local unit = workspace.Ignore.Units:FindFirstChild(unitId)
                        local currentUpgrade = unit and unit:GetAttribute("Upgrade") or 0
                        local unitName = unit and (unit:GetAttribute("UnitName") or unit.Name)
                        
                        if (not unitName or unitName:match("^{.*}$")) and inferredUnitName then
                            unitName = inferredUnitName
                        end
                        
                        local nextUpgradeCost = 0
                        if unitName then
                             local stats = TowerDataManager:GetTowerStats(unitName)
                             if stats and stats.Upgrades then
                                 local nextUp = stats.Upgrades[currentUpgrade + 1]
                                 if nextUp then nextUpgradeCost = nextUp.Cost end
                             end
                        end

                        local display = unitName and (unitName .. " (" .. unitId .. ")") or unitId
                        self:UpdateStatus(statusMsg, "Upgrade", display, "None")
                        local oldYen = LocalPlayer:GetAttribute("Yen") or 0
                        
                        if oldYen >= nextUpgradeCost then
                            local results = {TowerService.RF.UpgradeUnit:InvokeServer(unitId)}
                            if getgenv().UTD_DebugMode then
                                warn("[UTD Debug] UpgradeUnit:", unpack(results))
                            end
                            
                            task.wait(0.5)
                            local newYen = LocalPlayer:GetAttribute("Yen") or 0
                            
                            if newYen < oldYen then
                                success = true
                            else
                                self:UpdateStatus(statusMsg, "Upgrade", display, "Retrying...")
                                task.wait(0.5)
                            end
                        else
                            local costStr = (nextUpgradeCost > 0) and tostring(nextUpgradeCost) or "?"
                            self:UpdateStatus(statusMsg, "Upgrade", display, "Waiting for Money (" .. oldYen .. "/" .. costStr .. ")")
                            task.wait(0.5)
                        end
                    else
                        self:UpdateStatus(statusMsg, "Upgrade", inferredUnitName or "Searching...", "Unit Not Found")
                        task.wait(1)
                        attempts = attempts + 1
                    end
                until success or not self.IsPlaying or attempts > 100
                
            elseif step.Type == "Sell" then
                local pos = Vector3.new(step.Position.X, step.Position.Y, step.Position.Z)
                local cf = CFrame.new(pos)
                
                local attempts = 0
                repeat
                    local unitId = self:GetUnitIdAtPosition(cf)
                    if unitId then
                        self:UpdateStatus(statusMsg, "Sell", unitId, "None")
                        
                        local results = {TowerService.RF.SellUnit:InvokeServer(unitId)}
                        if getgenv().UTD_DebugMode then
                            warn("[UTD Debug] SellUnit:", unpack(results))
                        end
                        
                        success = true
                        
                        if self.PlacedHistory then
                             for i, placed in ipairs(self.PlacedHistory) do
                                 local dist = (Vector3.new(placed.X, 0, placed.Z) - Vector3.new(cf.Position.X, 0, cf.Position.Z)).Magnitude
                                 if dist < 1 then
                                     table.remove(self.PlacedHistory, i)
                                     break
                                 end
                             end
                        end
                        
                        task.wait(0.5)
                    else
                        self:UpdateStatus(statusMsg, "Sell", "Searching...", "Unit Not Found")
                        task.wait(1)
                        attempts = attempts + 1
                    end
                until success or not self.IsPlaying or attempts > 30
            
            elseif step.Type == "Ability" then
                local pos = Vector3.new(step.Position.X, step.Position.Y, step.Position.Z)
                local cf = CFrame.new(pos)
                
                local attempts = 0
                repeat
                    local unitId = self:GetUnitIdAtPosition(cf)
                    if unitId then
                        self:UpdateStatus(statusMsg, "Ability", unitId, "None")
                        
                        local remote = TowerService.RF:FindFirstChild(step.AbilityName) or TowerService.RE:FindFirstChild(step.AbilityName)
                        if remote then
                            local results = {}
                            if remote:IsA("RemoteFunction") then
                                results = {remote:InvokeServer(unitId)}
                            else
                                remote:FireServer(unitId)
                            end
                            
                            if getgenv().UTD_DebugMode then
                                warn("[UTD Debug] Ability (" .. step.AbilityName .. "):", unpack(results))
                            end
                            
                            success = true
                        else
                             self:UpdateStatus(statusMsg, "Ability", step.AbilityName, "Remote Not Found")
                             task.wait(1)
                             attempts = attempts + 1
                        end
                        task.wait(0.5)
                    else
                        self:UpdateStatus(statusMsg, "Ability", "Searching...", "Unit Not Found")
                        task.wait(1)
                        attempts = attempts + 1
                    end
                until success or not self.IsPlaying or attempts > 30
            end
            
            if success then
                stepIndex = stepIndex + 1
                task.wait(0.1)
            end
        end
    end)
end

