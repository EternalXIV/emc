local function SendGamePacket(config)
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local Event = ReplicatedStorage:FindFirstChild("ByteNetReliable")
    if not Event then return end

    local isChallenge = (config.ChallengeType ~= "None" and config.ChallengeType ~= nil)
    
    local size = 1 
    size = size + 2 + #config.Difficulty
    
    size = size + 1 
    if isChallenge then
        size = size + 1 
        size = size + 2 + #config.ChallengeType
    end
    
    size = size + 4 
    size = size + 2 + #config.Mode
    size = size + 2 + #config.Act
    size = size + 1 
    size = size + 2 + #config.MapName
    
    local b = buffer.create(size)
    local offset = 0
    
    buffer.writeu8(b, offset, 39)
    offset = offset + 1
    
    buffer.writeu16(b, offset, #config.Difficulty)
    offset = offset + 2
    buffer.writestring(b, offset, config.Difficulty)
    offset = offset + #config.Difficulty
    
    if isChallenge then
        buffer.writeu8(b, offset, 1)
        offset = offset + 1
        
        buffer.writeu8(b, offset, 1)
        offset = offset + 1
        
        buffer.writeu16(b, offset, #config.ChallengeType)
        offset = offset + 2
        buffer.writestring(b, offset, config.ChallengeType)
        offset = offset + #config.ChallengeType
    else
        buffer.writeu8(b, offset, 0)
        offset = offset + 1
    end
    
    buffer.writef32(b, offset, config.Multiplier)
    offset = offset + 4
    
    buffer.writeu16(b, offset, #config.Mode)
    offset = offset + 2
    buffer.writestring(b, offset, config.Mode)
    offset = offset + #config.Mode
    
    buffer.writeu16(b, offset, #config.Act)
    offset = offset + 2
    buffer.writestring(b, offset, config.Act)
    offset = offset + #config.Act
    
    buffer.writeu8(b, offset, config.FriendsOnly and 1 or 0)
    offset = offset + 1
    
    buffer.writeu16(b, offset, #config.MapName)
    offset = offset + 2
    buffer.writestring(b, offset, config.MapName)
    offset = offset + #config.MapName
    
    Event:FireServer(b)
    
    if config.AutoStart then
        task.wait(0.5)
        local startB = buffer.create(3)
        buffer.writeu8(startB, 0, 42)
        buffer.writeu8(startB, 1, 0)
        buffer.writeu8(startB, 2, 0)
        Event:FireServer(startB)
    end
end

