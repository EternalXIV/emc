function MacroManager:Initialize()
    if not isfolder(self.Folder) then makefolder(self.Folder) end
    self:LoadMacros()
    self:SetupHooks()
    self.PlacedHistory = {}
    
    task.spawn(function()
        local lastStatus, lastAction, lastUnit, lastWaiting
        while true do
            task.wait(0.1)
            if getgenv().UTD_Unload == nil then break end
            
            local Manager = getgenv().UTD_MacroManager
            if Manager then
                 if Manager.StatusText ~= lastStatus then
                     if Manager.StatusLabel then 
                        pcall(function() Manager.StatusLabel:UpdateName("Status: " .. Manager.StatusText) end)
                     end
                     lastStatus = Manager.StatusText
                 end
                 if Manager.ActionText ~= lastAction then
                     if Manager.ActionLabel then 
                        pcall(function() Manager.ActionLabel:UpdateName("Action: " .. Manager.ActionText) end)
                     end
                     lastAction = Manager.ActionText
                 end
                 if Manager.UnitText ~= lastUnit then
                     if Manager.UnitLabel then 
                        pcall(function() Manager.UnitLabel:UpdateName("Unit: " .. Manager.UnitText) end)
                     end
                     lastUnit = Manager.UnitText
                 end
                 if Manager.WaitingText ~= lastWaiting then
                     if Manager.WaitingLabel then 
                        pcall(function() Manager.WaitingLabel:UpdateName("Waiting: " .. Manager.WaitingText) end)
                     end
                     lastWaiting = Manager.WaitingText
                 end
            end
        end
    end)
end

