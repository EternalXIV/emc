task.spawn(function()
    local Mouse = LocalPlayer:GetMouse()
    
    local currentGhost = nil
    local lastGhostData = {Name = nil, Rotation = 0, Time = 0}
    
    local function setupGhostTracking()
        local ghostFolder = workspace:WaitForChild("Ignore", 5) and workspace.Ignore:WaitForChild("GhostUnits", 5)
        if ghostFolder then
            ghostFolder.ChildAdded:Connect(function(child)
                currentGhost = child
            end)
            
            ghostFolder.ChildRemoved:Connect(function(child)
                if currentGhost == child then
                    lastGhostData.Name = child.Name
                    lastGhostData.Time = tick()
                    local primary = child.PrimaryPart or child:FindFirstChild("HumanoidRootPart")
                    if primary then
                        local _, y, _ = primary.CFrame:ToOrientation()
                        lastGhostData.Rotation = y
                    end
                    currentGhost = nil
                end
            end)
        end
    end
    setupGhostTracking()

    local connection
    connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if getgenv().UTD_Unload == nil then 
            if connection then connection:Disconnect() end
            return 
        end
        
        if game.PlaceId ~= 106402284955512 then return end
        if not getgenv().UTD_PlaceAnywhere then return end
        
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local unitNameToPlace = nil
            local rotationToPlace = 0
            
            if currentGhost and currentGhost.Parent then
                unitNameToPlace = currentGhost.Name
                local primary = currentGhost.PrimaryPart or currentGhost:FindFirstChild("HumanoidRootPart")
                if primary then
                    local _, y, _ = primary.CFrame:ToOrientation()
                    rotationToPlace = y
                end
            elseif (tick() - lastGhostData.Time) < 0.5 and lastGhostData.Name then
                unitNameToPlace = lastGhostData.Name
                rotationToPlace = lastGhostData.Rotation
                if getgenv().UTD_DebugMode then
                    warn("[UTD] Place Anywhere: Using cached ghost unit data for " .. tostring(unitNameToPlace))
                end
            else
                local ghostFolder = workspace:FindFirstChild("Ignore") and workspace.Ignore:FindFirstChild("GhostUnits")
                if ghostFolder then
                    local children = ghostFolder:GetChildren()
                    if children[1] then
                        unitNameToPlace = children[1].Name
                        local primary = children[1].PrimaryPart or children[1]:FindFirstChild("HumanoidRootPart")
                        if primary then
                            local _, y, _ = primary.CFrame:ToOrientation()
                            rotationToPlace = y
                        end
                    end
                end
            end
            
            if unitNameToPlace then
                local slot = UnitDataManager:GetSlotFromUnitName(unitNameToPlace)
                
                if slot then
                    local targetCFrame = Mouse.Hit
                    targetCFrame = CFrame.new(targetCFrame.Position) * CFrame.Angles(0, rotationToPlace, 0)
                    
                    task.wait(0.4)
                    
                    local alreadyPlaced = false
                    local unitsFolder = workspace:FindFirstChild("Ignore") and workspace.Ignore:FindFirstChild("Units")
                    if unitsFolder then
                        for _, unit in ipairs(unitsFolder:GetChildren()) do
                            local hrp = unit:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                local dist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(targetCFrame.Position.X, 0, targetCFrame.Position.Z)).Magnitude
                                if dist < 1 then
                                    alreadyPlaced = true
                                    break
                                end
                            end
                        end
                    end
                    
                    if not alreadyPlaced then
                        local TowerService = game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit.Services.TowerService
                        TowerService.RF.PlaceUnit:InvokeServer(slot, targetCFrame)
                        
                        if getgenv().UTD_DebugMode then
                            warn("[UTD] Place Anywhere: Placed " .. unitNameToPlace .. " (Slot " .. slot .. ")")
                        end
                    elseif getgenv().UTD_DebugMode then
                        warn("[UTD] Place Anywhere: Skipped (Game placed unit normally)")
                    end
                else
                     if getgenv().UTD_DebugMode then
                        warn("[UTD] Place Anywhere: Could not find slot for " .. tostring(unitNameToPlace))
                    end
                end
            end
        end
    end)
end)

